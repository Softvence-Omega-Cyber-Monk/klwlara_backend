model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  role       Role      @default(USER)
  profileImg String?
  products   UserProducts[] // one user → many products
  sentChats     Chat[] @relation("sentMessages")      // 👈 messages sent by this user
  receivedChats Chat[] @relation("receivedMessages") // 👈 messages received by this user
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum Role {
  USER
  ADMIN
}
