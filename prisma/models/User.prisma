model User {
  id         String         @id @default(cuid())
  name       String
  email      String         @unique
  password   String
  role       Role           @default(USER)
  profileImg String?
  products   UserProducts[] // 👈 one user → many products
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}
